# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Phase 6 — image layer. Without this, backgrounds render as deterministic
# on-palette placeholders. With it, `npm run scenes:bake` generates real
# gpt-image-1 backgrounds (cached to assets/generated/<scene>.png).
OPENAI_API_KEY=

# Phase 9/10 — dashboard + hosting (not yet wired)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_BUCKET=
# DASHBOARD_KEY=
